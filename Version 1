    function generateRepairQuoteFromInspection(employer, inspection) {
        var worker = getTailor(inspection.workerId);
        var product = CONFIG.products[String(inspection.productKey || '')];
        var repairableRoll = rollInteger(1, 100);
        var repairPct = rollInteger(CONFIG.repairCostMinPct, CONFIG.repairCostMaxPct);
        var quote, actualRepairDays, notes;
        if (!worker || !product) return null;
        if (repairableRoll <= CONFIG.repairNotRepairablePct) {
            inspection.status = 'complete';
            inspection.notes = 'Not repairable.';
            inspection.result = 'not-repairable';
            inspection.repairableRoll = repairableRoll;
            return {
                type: 'not-repairable',
                html: box('Repair Inspection Result',
                    line('Tailor', esc(worker.name)) +
                    line('Item', esc(product.label)) +
                    line('Inspection roll', esc(repairableRoll)) +
                    line('Beyond-repair threshold', esc(CONFIG.repairNotRepairablePct + '% not repairable')) +
                    '<div>The tailor judges the item beyond repair after one day of inspection work.</div>' +
                    btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
                )
            };
        }
        actualRepairDays = repairActualDays(product, worker.efficiency);
        notes = 'Repair quote generated after 1 inspection day. Repair time is estimated as roughly one-quarter of full production time.';
        quote = createQuote(employer, worker, {
            description: 'Repair ' + product.label,
            quantity: 1,
            category: product.category,
            support: product.support,
            cloth: product.cloth,
            days: actualRepairDays,
            humanDays: actualRepairDays,
            basePriceGp: (product.basePriceGp || 0) * (repairPct / 100),
            extraCostGp: 0,
            productKey: product.key,
            notes: notes,
            quoteType: 'repair',
            skipRandomVariance: true
        });
        quote.repairPct = repairPct;
        quote.repairableRoll = repairableRoll;
        inspection.status = 'complete';
        inspection.result = 'quoted';
        inspection.generatedQuoteId = quote.id;
        inspection.repairableRoll = repairableRoll;
        return { type: 'quote', quote: quote, html: box('Repair Inspection Result', quoteSummaryHtml(quote, true)) };
    }

    function handleCounteroffer(msg, args) {
        var employer = requireEmployer(msg, args);
        var quote, roll, success, haggleTarget, newNegotiableCp, resultText;
        if (!employer) return;
        quote = getQuote(args.quote);
        if (!quote || String(quote.employerId) !== String(employer.id)) {
            send(box('Haggle Price', '<div>Quote not found.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        if (quote.haggleDone) {
            send(box('Haggle Price', line('Job', esc(quote.description)) + '<div>Haggling is already finished for this quote.</div>' + btn('View Quotes', '!tailor-quotes --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        roll = rollInteger(1, 100);
        haggleTarget = Math.max(0, Math.min(95, 10 + toNumber(quote.reactionBonus, 0)));
        success = roll <= haggleTarget;
        quote.haggleAttempts = (quote.haggleAttempts || 0) + 1;
        if (success) {
            newNegotiableCp = Math.max(quote.floorNegotiableCp, Math.round(quote.currentNegotiableCp * 0.95));
            quote.currentNegotiableCp = newNegotiableCp;
            quote.currentQuoteCp = quote.fixedCostCp + newNegotiableCp;
            quote.depositCp = Math.ceil(quote.currentQuoteCp / 2);
            quote.balanceDueCp = quote.currentQuoteCp - quote.depositCp;
            quote.haggleDone = true;
            resultText = '<span style="color:#8fe38f;font-weight:bold;">Success - tailor reduces the quoted craft charge by 5%.</span>';
        } else {
            quote.haggleFailures = (quote.haggleFailures || 0) + 1;
            quote.lastHaggleComment = CONFIG.haggleFailComments[rollInteger(0, CONFIG.haggleFailComments.length - 1)];
            if (quote.haggleFailures >= 2) {
                quote.currentNegotiableCp = Math.round(quote.currentNegotiableCp * 1.10);
                quote.currentQuoteCp = quote.fixedCostCp + quote.currentNegotiableCp;
                quote.depositCp = Math.ceil(quote.currentQuoteCp / 2);
                quote.balanceDueCp = quote.currentQuoteCp - quote.depositCp;
                quote.haggleDone = true;
                resultText = '<span style="color:#ff7b7b;font-weight:bold;">Second failure - tailor raises the craft charge by 10% and ends haggling.</span>';
            } else {
                resultText = '<span style="color:#ffb36b;font-weight:bold;">Failure - no change yet. One more haggle attempt remains.</span>';
            }
        }
        send(box('Haggle Result',
            line('Job', esc(quote.description)) +
            line('Haggle target', esc(haggleTarget + '%')) +
            line('Die roll', esc(roll)) +
            line('Result', resultText) +
            ((!success && quote.lastHaggleComment) ? line('Tailor says', esc(quote.lastHaggleComment)) : '') +
            line('Current quote', '<span style="color:#ffd25e;font-weight:bold;">' + esc(formatCp(quote.currentQuoteCp)) + '</span>') +
            line('Half down now', esc(formatCp(quote.depositCp))) +
            line('Balance on pickup', esc(formatCp(quote.balanceDueCp))) +
            '<div style="margin-top:8px;">' +
                btn('Place Order', '!tailor-accept-quote --pc|' + employer.id + ' --quote|' + quote.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
                (!quote.haggleDone ? btn('Haggle Price', '!tailor-counteroffer --pc|' + employer.id + ' --quote|' + quote.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) : '') +
                btn('Deny Quote', '!tailor-deny-quote --pc|' + employer.id + ' --quote|' + quote.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 110) +
                btn('View Quotes', '!tailor-quotes --pc|' + employer.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) +
                btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
            '</div>'
        ));
    }

    function handleAcceptQuote(msg, args) {
        var employer = requireEmployer(msg, args);
        var quote, payResult, job, depositCp, balanceCp;
        if (!employer) return;
        quote = getQuote(args.quote);
        if (!quote || String(quote.employerId) !== String(employer.id)) {
            send(box('Place Order', '<div>Quote not found.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        depositCp = quote.depositCp || Math.ceil(quote.currentQuoteCp / 2);
        balanceCp = typeof quote.balanceDueCp === 'number' ? quote.balanceDueCp : (quote.currentQuoteCp - depositCp);
        payResult = payCostOrReport(employer, depositCp);
        if (!payResult.ok) {
            send(box('Place Order',
                line('Employer', esc(employer.get('name'))) +
                line('Needed now', esc(formatCp(payResult.needed))) +
                line('On hand', esc(formatCp(payResult.onHand))) +
                '<div>Not enough coin on the PC sheet for the half-down payment.</div>' +
                btn('View Quotes', '!tailor-quotes --pc|' + employer.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110)
            ));
            return;
        }
        job = {
            id: generateJobId(),
            workerId: quote.workerId,
            workerName: quote.workerName,
            employerId: employer.id,
            description: quote.description,
            actualDays: quote.actualDays,
            elapsedDays: 0,
            status: 'active',
            finalCostCp: quote.currentQuoteCp,
            upfrontPaidCp: depositCp,
            balanceDueCp: balanceCp,
            support: quote.support || [],
            notes: 'Order placed. Half down paid: ' + formatCp(depositCp) + '. Haggle attempts: ' + (quote.haggleAttempts || 0) + '.',
            quoteType: quote.quoteType || 'standard'
        };
        state[STATE].jobs.push(job);
        removeQuote(quote.id);
        send(box('Order Placed',
            line('Employer', esc(employer.get('name'))) +
            line('Job', esc(job.description)) +
            line('Tailor', esc(job.workerName)) +
            line('Half down paid', esc(formatCp(job.upfrontPaidCp))) +
            line('Balance due on pickup', esc(formatCp(job.balanceDueCp))) +
            line('Time to complete', esc(job.actualDays + ' day(s)')) +
            btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
    }

    function handleDenyQuote(msg, args) {
        var employer = requireEmployer(msg, args);
        var quote;
        if (!employer) return;
        quote = getQuote(args.quote);
        if (!quote || String(quote.employerId) !== String(employer.id)) {
            send(box('Deny Quote', '<div>Quote not found.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        removeQuote(quote.id);
        send(box('Quote Denied',
            line('Employer', esc(employer.get('name'))) +
            line('Tailor', esc(quote.workerName)) +
            line('Job', esc(quote.description)) +
            '<div>The quote was removed.</div>' +
            btn('View Quotes', '!tailor-quotes --pc|' + employer.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
    }

    function handleQuotes(msg, args) {
        var employer = requireEmployer(msg, args);
        var quotes, body;
        if (!employer) return;
        quotes = getEmployerQuotes(employer.id);
        if (!quotes.length) {
            send(box('Open Quotes', line('Employer', esc(employer.get('name'))) + '<div>No open quotes.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        body = _.map(quotes, function (quote) {
            return '<div style="margin-bottom:8px;padding-bottom:8px;border-bottom:1px solid #2e2e2e;">' + quoteSummaryHtml(quote, true) + '</div>';
        }).join('');
        send(box('Open Quotes', line('Employer', esc(employer.get('name'))) + body + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
    }

    function inspectionSummary(inspection) {
        return '<div style="margin:4px 0 8px 0;padding-bottom:6px;border-bottom:1px solid #2e2e2e;">' +
            line('Inspection', esc(inspection.description)) +
            line('Tailor', esc(inspection.workerName)) +
            line('Progress', esc(inspection.elapsedDays + ' / ' + inspection.actualDays + ' day(s)')) +
            line('Status', esc(inspection.status)) +
            (inspection.notes ? '<div style="color:' + CONFIG.colors.subtext + ';">' + esc(inspection.notes) + '</div>' : '') +
            '</div>';
    }

    function jobSummary(job, showPickup) {
        var body = '<div style="margin:4px 0 8px 0;padding-bottom:6px;border-bottom:1px solid #2e2e2e;">' +
            line('Job', esc(job.description)) +
            line('Tailor', esc(job.workerName)) +
            line('Progress', esc(job.elapsedDays + ' / ' + job.actualDays + ' day(s)')) +
            line('Status', esc(job.status)) +
            line('Paid now', esc(formatCp(job.upfrontPaidCp || 0))) +
            line('Balance due', esc(formatCp(job.balanceDueCp || 0))) +
            (job.notes ? '<div style="color:' + CONFIG.colors.subtext + ';">' + esc(job.notes) + '</div>' : '');
        if (showPickup && job.status === 'ready') {
            body += btn('Pick Up Order', '!tailor-pickup --pc|' + job.employerId + ' --job|' + job.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110);
        }
        body += '</div>';
        return body;
    }

    function handleReport(msg, args) {
        var employer = requireEmployer(msg, args);
        var inspections, jobs, body = '';
        if (!employer) return;
        inspections = getEmployerInspections(employer.id);
        jobs = getEmployerJobs(employer.id);
        body += line('Employer', esc(employer.get('name')));
        body += sectionHeader('Open inspections');
        body += inspections.length ? _.map(inspections, inspectionSummary).join('') : '<div>No active inspections.</div>';
        body += sectionHeader('Open jobs');
        body += jobs.length ? _.map(jobs, function (job) { return jobSummary(job, true); }).join('') : '<div>No active or ready jobs.</div>';
        body += btn('Apply Days', '!tailor-apply-days --pc|' + employer.id + ' --days|?{Days passed|1}', CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
            btn('View Quotes', '!tailor-quotes --pc|' + employer.id, CONFIG.colors.warnBg, CONFIG.colors.warnBorder, 110) +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110);
        send(box('Tailor Shop Work Progress', body));
    }

    function handleApplyDays(msg, args) {
        var employer = requireEmployer(msg, args);
        var days = Math.max(1, parseInt(args.days || 1, 10));
        var inspections, jobs, notices = [];
        if (!employer) return;
        inspections = _.filter(getEmployerInspections(employer.id), function (i) { return i.status === 'active'; });
        jobs = _.filter(getEmployerJobs(employer.id), function (j) { return j.status === 'active'; });

        _.each(inspections, function (inspection) {
            inspection.elapsedDays += days;
            if (inspection.elapsedDays >= inspection.actualDays) {
                var result = generateRepairQuoteFromInspection(employer, inspection);
                if (result && result.html) notices.push(result.html);
            }
        });

        _.each(jobs, function (job) {
            job.elapsedDays += days;
            if (job.elapsedDays >= job.actualDays) {
                job.elapsedDays = job.actualDays;
                job.status = 'ready';
                notices.push(box('Order Ready',
                    line('Employer', esc(employer.get('name'))) +
                    line('Job', esc(job.description)) +
                    line('Tailor', esc(job.workerName)) +
                    line('Balance due', esc(formatCp(job.balanceDueCp || 0))) +
                    btn('Pick Up Order', '!tailor-pickup --pc|' + employer.id + ' --job|' + job.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
                    btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
                ));
            }
        });

        state[STATE].inspections = _.reject(state[STATE].inspections, function (inspection) {
            return String(inspection.employerId) === String(employer.id) && inspection.status === 'complete';
        });

        if (!notices.length) {
            send(box('Apply Days',
                line('Employer', esc(employer.get('name'))) +
                line('Days applied', esc(days)) +
                '<div>No inspections finished and no jobs became ready.</div>' +
                btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
                btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
            ));
            return;
        }
        send(notices.join(''));
    }

    function handlePickup(msg, args) {
        var employer = requireEmployer(msg, args);
        var job, payResult;
        if (!employer) return;
        job = getJob(args.job);
        if (!job || String(job.employerId) !== String(employer.id)) {
            send(box('Pick Up Order', '<div>Job not found.</div>' + btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        if (job.status !== 'ready') {
            send(box('Pick Up Order', '<div>That order is not ready for pickup yet.</div>' + btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        payResult = payCostOrReport(employer, job.balanceDueCp || 0);
        if (!payResult.ok) {
            send(box('Pick Up Order',
                line('Employer', esc(employer.get('name'))) +
                line('Needed now', esc(formatCp(payResult.needed))) +
                line('On hand', esc(formatCp(payResult.onHand))) +
                '<div>Not enough coin on the PC sheet for pickup.</div>' +
                btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
            ));
            return;
        }
        job.status = 'complete';
        send(box('Order Picked Up',
            line('Employer', esc(employer.get('name'))) +
            line('Job', esc(job.description)) +
            line('Tailor', esc(job.workerName)) +
            line('Balance paid', esc(formatCp(job.balanceDueCp || 0))) +
            '<div>The order has been completed and removed from the active queue.</div>' +
            btn('Work Progress', '!tailor-report --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
        state[STATE].jobs = _.reject(state[STATE].jobs, function (j) { return String(j.id) === String(job.id); });
    }

    function handleRemoveWorkerMenu(msg, args) {
        var employer = requireEmployer(msg, args);
        if (!employer) return;
        if (!getAllTailors().length) {
            send(box('Remove Tailor', '<div>No tailors are recorded in the campaign yet.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        send(box('Remove Tailor',
            '<div>Choose the tailor to remove from the campaign pool.</div>' +
            buildWorkerButtons(employer, '!tailor-remove-worker', CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder) +
            '<div style="margin-top:8px;">' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) + '</div>'
        ));
    }

    function handleRemoveWorker(msg, args) {
        var employer = requireEmployer(msg, args);
        var worker;
        if (!employer) return;
        worker = getTailor(args.worker);
        if (!worker) {
            send(box('Remove Tailor', '<div>Tailor not found.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        state[STATE].tailors = _.reject(state[STATE].tailors, function (w) { return String(w.id) === String(worker.id); });
        state[STATE].quotes = _.reject(state[STATE].quotes, function (q) { return String(q.workerId) === String(worker.id); });
        state[STATE].jobs = _.reject(state[STATE].jobs, function (j) { return String(j.workerId) === String(worker.id); });
        state[STATE].inspections = _.reject(state[STATE].inspections, function (i) { return String(i.workerId) === String(worker.id); });
        send(box('Tailor Removed',
            line('Employer', esc(employer.get('name'))) +
            line('Tailor', esc(worker.name)) +
            '<div>The tailor and any open quotes, jobs, or inspections tied to that worker were removed.</div>' +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
    }

    function handleRemoveAll(msg, args) {
        var employer = requireEmployer(msg, args);
        if (!employer) return;
        if (!isAffirmative(args.confirm)) {
            send(box('Remove All Tailors', '<div>Removal cancelled.</div>' + btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        state[STATE].tailors = [];
        state[STATE].quotes = [];
        state[STATE].jobs = [];
        state[STATE].inspections = [];
        send(box('Remove All Tailors',
            line('Employer', esc(employer.get('name'))) +
            '<div>All tailors and all open tailor-shop quotes, jobs, and inspections were removed.</div>' +
            btn('Main Menu', '!tailor-menu --pc|' + employer.id, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
    }

    function handleReset(msg, args) {
        if (!playerIsGM(msg.playerid)) {
            send(box('Reset Campaign', '<div>Only the GM can reset the cloth shop script.</div>'));
            return;
        }
        if (!isAffirmative(args.confirm)) {
            send(box('Reset Campaign', '<div>Reset cancelled.</div>' + btn('Main Menu', '!tailor-menu', CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
            return;
        }
        state[STATE] = {
            version: VERSION,
            nextTailorId: 1,
            nextQuoteId: 1,
            nextJobId: 1,
            nextInspectionId: 1,
            tailors: [],
            quotes: [],
            jobs: [],
            inspections: []
        };
        send(box('Reset Campaign', '<div>All Tailor Shop campaign data has been reset.</div>' + btn('Main Menu', '!tailor-menu', CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)));
    }

    function handleInput(msg) {
        var args, cmd;
        if (msg.type !== 'api') return;
        if (!msg.content || msg.content.indexOf('!tailor-') !== 0) return;
        setWhisperTarget(msg);
        args = parseArgs(msg.content);
        cmd = msg.content.split(' ')[0];

        switch (cmd) {
        case '!tailor-menu': handleMenu(msg, args); break;
        case '!tailor-add-worker': handleAddWorker(msg, args); break;
        case '!tailor-quote-start': handleQuoteStart(msg, args); break;
        case '!tailor-repair-start': handleRepairStart(msg, args); break;
        case '!tailor-custom-start': handleCustomStart(msg, args); break;
        case '!tailor-price-list': handlePriceList(msg, args); break;
        case '!tailor-quote-menu': handleQuoteMenu(msg, args); break;
        case '!tailor-custom-menu': handleCustomMenu(msg, args); break;
        case '!tailor-repair-menu': handleRepairMenu(msg, args); break;
        case '!tailor-quote-standard': handleQuoteStandard(msg, args); break;
        case '!tailor-custom-quote': handleCustomQuote(msg, args); break;
        case '!tailor-repair-inspect': handleRepairInspect(msg, args); break;
        case '!tailor-counteroffer': handleCounteroffer(msg, args); break;
        case '!tailor-accept-quote': handleAcceptQuote(msg, args); break;
        case '!tailor-deny-quote': handleDenyQuote(msg, args); break;
        case '!tailor-quotes': handleQuotes(msg, args); break;
        case '!tailor-report': handleReport(msg, args); break;
        case '!tailor-apply-days': handleApplyDays(msg, args); break;
        case '!tailor-pickup': handlePickup(msg, args); break;
        case '!tailor-remove-worker-menu': handleRemoveWorkerMenu(msg, args); break;
        case '!tailor-remove-worker': handleRemoveWorker(msg, args); break;
        case '!tailor-remove-all': handleRemoveAll(msg, args); break;
        case '!tailor-reset': handleReset(msg, args); break;
        default: handleUnknown(msg, cmd, args); break;
        }
    }

    function handleUnknown(msg, cmd, args) {
        var employer = resolveEmployer(msg, args);
        send(box('Tailor Shop',
            line('Command', esc(cmd || 'unknown')) +
            '<div>That tailor-shop button or command did not match a valid handler.</div>' +
            btn('Main Menu', employer ? '!tailor-menu --pc|' + employer.id : '!tailor-menu', CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110)
        ));
    }

    return {
        CheckInstall: stateInit,
        RegisterEventHandlers: registerEventHandlers
    };
}());

on('ready', function () {
    'use strict';
    TailorShop.CheckInstall();
    TailorShop.RegisterEventHandlers();
});

