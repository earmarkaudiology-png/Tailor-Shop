                btn('Deny Quote', '!tailor-deny-quote --pc|' + quote.employerId + ' --quote|' + quote.id, CONFIG.colors.dangerBg, CONFIG.colors.dangerBorder, 110) +
                btn('Main Menu', '!tailor-menu --pc|' + quote.employerId, CONFIG.colors.reportBg, CONFIG.colors.reportBorder, 110) +
                '</div>';
        }
        return body;
    }

